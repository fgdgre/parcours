  { "id": "v1-13", "fr": "c'est", "en": "it is, this is", "ipa": "/sɛ/", "exFr": "C'est une bonne question.", "exEn": "It's a good question.", "tags": ["chunks"] },
  { "id": "v1-14", "fr": "ce n'est pas", "en": "it is not", "ipa": "/sə nɛ pɑ/", "exFr": "Ce n'est pas possible.", "exEn": "It's not possible.", "tags": ["chunks", "negation"] },
  { "id": "v1-15", "fr": "je suis", "en": "I am", "ipa": "/ʒə sɥi/", "exFr": "Je suis ici.", "exEn": "I am here.", "tags": ["chunks", "être"] },
