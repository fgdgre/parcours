  { "id": "v1-37", "fr": "combien", "en": "how much, how many", "ipa": "/kɔ̃.bjɛ̃/", "exFr": "C'est combien ?", "exEn": "How much is it?", "tags": ["questions"] },
  { "id": "v1-38", "fr": "et", "en": "and", "ipa": "/e/", "exFr": "Toi et moi.", "exEn": "You and me.", "tags": ["connectors"] },
  { "id": "v1-39", "fr": "ou", "en": "or", "ipa": "/u/", "exFr": "Café ou thé ?", "exEn": "Coffee or tea?", "tags": ["connectors"] },
  { "id": "v1-40", "fr": "mais", "en": "but", "ipa": "/mɛ/", "exFr": "Oui, mais pas maintenant.", "exEn": "Yes, but not now.", "tags": ["connectors"] },
  { "id": "v1-41", "fr": "avec", "en": "with", "ipa": "/a.vɛk/", "exFr": "Je vais avec toi.", "exEn": "I'm going with you.", "tags": ["prepositions"] },
