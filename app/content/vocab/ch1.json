  { "id": "v1-44", "fr": "bien", "en": "well, good", "ipa": "/bjɛ̃/", "exFr": "Très bien, merci.", "exEn": "Very well, thank you.", "tags": ["adverbs"] },
  { "id": "v1-45", "fr": "beaucoup", "en": "a lot, much", "ipa": "/bo.ku/", "exFr": "Merci beaucoup.", "exEn": "Thanks a lot.", "tags": ["adverbs"] },
