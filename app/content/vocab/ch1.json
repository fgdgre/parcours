[
  { "id": "v1-01", "fr": "bonjour", "en": "hello, good day", "ipa": "/bɔ̃.ʒuʁ/", "exFr": "Bonjour, ça va ?", "exEn": "Hello, how are you?", "tags": ["greetings"] },
  { "id": "v1-02", "fr": "bonsoir", "en": "good evening", "ipa": "/bɔ̃.swaʁ/", "exFr": "Bonsoir, monsieur.", "exEn": "Good evening, sir.", "tags": ["greetings"] },
  { "id": "v1-03", "fr": "salut", "en": "hi (informal)", "ipa": "/sa.ly/", "exFr": "Salut ! Ça va ?", "exEn": "Hi! How's it going?", "tags": ["greetings"] },
  { "id": "v1-04", "fr": "au revoir", "en": "goodbye", "ipa": "/o ʁə.vwaʁ/", "exFr": "Au revoir et merci !", "exEn": "Goodbye and thank you!", "tags": ["greetings"] },
  { "id": "v1-05", "fr": "merci", "en": "thank you", "ipa": "/mɛʁ.si/", "exFr": "Merci beaucoup !", "exEn": "Thank you very much!", "tags": ["politeness"] },
  { "id": "v1-06", "fr": "s'il vous plaît", "en": "please (formal)", "ipa": "/sil vu plɛ/", "exFr": "Un café, s'il vous plaît.", "exEn": "A coffee, please.", "tags": ["politeness"] },
  { "id": "v1-07", "fr": "pardon", "en": "sorry, excuse me", "ipa": "/paʁ.dɔ̃/", "exFr": "Pardon, je ne comprends pas.", "exEn": "Sorry, I don't understand.", "tags": ["politeness"] },
  { "id": "v1-08", "fr": "oui", "en": "yes", "ipa": "/wi/", "exFr": "Oui, c'est possible.", "exEn": "Yes, it's possible.", "tags": ["core"] },
  { "id": "v1-09", "fr": "non", "en": "no", "ipa": "/nɔ̃/", "exFr": "Non, merci.", "exEn": "No, thank you.", "tags": ["core"] },
  { "id": "v1-10", "fr": "peut-être", "en": "maybe", "ipa": "/pø.tɛtʁ/", "exFr": "Peut-être demain.", "exEn": "Maybe tomorrow.", "tags": ["core"] },
