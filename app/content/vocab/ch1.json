  { "id": "v1-50", "fr": "monsieur / madame", "en": "sir / madam", "ipa": "/mə.sjø/ /ma.dam/", "exFr": "Bonjour, madame.", "exEn": "Good day, madam.", "tags": ["politeness"] }
