  { "id": "v1-18", "fr": "je veux", "en": "I want", "ipa": "/ʒə vø/", "exFr": "Je veux parler français.", "exEn": "I want to speak French.", "tags": ["chunks", "vouloir"] },
  { "id": "v1-19", "fr": "je voudrais", "en": "I would like (polite)", "ipa": "/ʒə vu.dʁɛ/", "exFr": "Je voudrais un café.", "exEn": "I would like a coffee.", "tags": ["chunks", "politeness"] },
