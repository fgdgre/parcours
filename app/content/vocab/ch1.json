  { "id": "v1-33", "fr": "où", "en": "where", "ipa": "/u/", "exFr": "Où est la gare ?", "exEn": "Where is the station?", "tags": ["questions"] },
  { "id": "v1-34", "fr": "quand", "en": "when", "ipa": "/kɑ̃/", "exFr": "Quand est-ce que tu vas venir ?", "exEn": "When are you going to come?", "tags": ["questions"] },
  { "id": "v1-35", "fr": "comment", "en": "how", "ipa": "/kɔ.mɑ̃/", "exFr": "Comment ça va ?", "exEn": "How is it going?", "tags": ["questions"] },
